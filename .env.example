# ─────────────────────────────────────────────────────────────────
# Telecom Semantic KB — Environment Config
# Copy to .env and fill in your values
#
# 网络环境说明：
#   NAS  192.168.3.71  — pgvector / neo4j / mongo / minio / crawlab
#   PC   192.168.3.211 — WSL2, RTX 3060, BGE-M3 :8000, Ollama :11434
#   WSL2 mirrored 模式，端口 8000/11434 已通过 netsh portproxy 映射到 Windows
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL — Knowledge DB (NAS Docker: pgvector/pgvector:pg16) ─
POSTGRES_HOST=192.168.3.71
POSTGRES_PORT=5432
POSTGRES_DB=telecom_kb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_pg_password
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10
POSTGRES_ADMIN_DB=postgres
POSTGRES_AUTO_CREATE=false

# ── PostgreSQL — Crawler DB (separate database, same PG instance) ─
# Defaults to same host/user/password as knowledge DB if left empty.
CRAWLER_POSTGRES_HOST=             # defaults to POSTGRES_HOST
CRAWLER_POSTGRES_PORT=0            # defaults to POSTGRES_PORT (0 = use default)
CRAWLER_POSTGRES_DB=telecom_crawler
CRAWLER_POSTGRES_USER=             # defaults to POSTGRES_USER
CRAWLER_POSTGRES_PASSWORD=         # defaults to POSTGRES_PASSWORD
CRAWLER_POSTGRES_POOL_MIN=1
CRAWLER_POSTGRES_POOL_MAX=5
CRAWLER_POSTGRES_AUTO_CREATE=false

# ── Neo4j (NAS Docker: neo4j:latest, Community 2026.03.1) ─────────
# Web UI: http://192.168.3.71:7474  Bolt: bolt://192.168.3.71:7687
NEO4J_URI=bolt://192.168.3.71:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ── MinIO (NAS Docker: minio/minio) ──────────────────────────────
# Console: http://192.168.3.71:9001  API: http://192.168.3.71:9000
MINIO_ENDPOINT=192.168.3.71:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_RAW=telecom-kb-raw
MINIO_BUCKET_CLEANED=telecom-kb-cleaned
MINIO_SECURE=false

# ── LLM (DeepSeek 原生 API) ───────────────────────────────────────
# 文档：https://platform.deepseek.com/api-docs
# 模型：deepseek-chat (DeepSeek-V3) / deepseek-reasoner (R1)
LLM_ENABLED=true
LLM_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=1024

# ── Embedding (本地 Ollama BGE-M3, 1024-dim) ─────────────────────
# PC WSL2 Ollama 服务，显存占用 ~2.5GB（与 Qwen 共享 12GB）
# 确认 bge-m3 已加载：curl http://localhost:11434/api/tags
# 拉取命令：ollama pull bge-m3
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=BAAI/bge-m3           # sentence-transformers fallback（通常不需要）
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIM=1024

OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3

# ── Pipeline ─────────────────────────────────────────────────────
ONTOLOGY_VERSION=v0.2.0
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_PREFIX=app
LOG_FILE_MAX_MB=5
LOG_FILE_ENABLED=true
STARTUP_HEALTH_REQUIRED=true
APP_PORT=8001                         # 避开 WSL2 BGE-M3 占用的 :8000
APP_HOST=0.0.0.0

# Worker (crawler + pipeline)
WORKER_CRAWL_LIMIT=10
WORKER_PIPELINE_LIMIT=10
WORKER_SLEEP_SECS=30
