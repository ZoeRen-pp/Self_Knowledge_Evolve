# ─────────────────────────────────────────
# Telecom Semantic KB — Environment Config
# Copy to .env and fill in your values
# ─────────────────────────────────────────

# ── PostgreSQL — Knowledge DB (Docker container) ─
POSTGRES_HOST=127.0.0.1          # container name if on same Docker network, e.g. telecom-kb-postgres
POSTGRES_PORT=5432
POSTGRES_DB=telecom_kb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=982012
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10
POSTGRES_ADMIN_DB=postgres
POSTGRES_AUTO_CREATE=false

# ── PostgreSQL — Crawler DB (separate database) ─
# Defaults to same host/user/password as knowledge DB if left empty.
CRAWLER_POSTGRES_HOST=             # defaults to POSTGRES_HOST
CRAWLER_POSTGRES_PORT=0            # defaults to POSTGRES_PORT (0 = use default)
CRAWLER_POSTGRES_DB=telecom_crawler
CRAWLER_POSTGRES_USER=             # defaults to POSTGRES_USER
CRAWLER_POSTGRES_PASSWORD=         # defaults to POSTGRES_PASSWORD
CRAWLER_POSTGRES_POOL_MIN=1
CRAWLER_POSTGRES_POOL_MAX=5
CRAWLER_POSTGRES_AUTO_CREATE=false

# ── Neo4j (Docker container) ─────────────
NEO4J_URI=bolt://localhost:7687  # e.g. bolt://telecom-kb-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=982012
NEO4J_DATABASE=neo4j             # default database name

# ── MinIO / S3-compatible object storage ─
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=telecom-kb-raw
MINIO_BUCKET_CLEANED=telecom-kb-cleaned
MINIO_SECURE=false               # true if using HTTPS

# ── Vector index (pgvector, same PG instance) ─
# No extra config needed; uses the POSTGRES_* vars above.
# Set to qdrant/milvus URI if switching later:
# VECTOR_BACKEND=pgvector
# VECTOR_BACKEND_URI=

# ── LLM (relation extraction via Claude API) ─────────────────
# Set LLM_ENABLED=true and provide your API key to activate LLM extraction
LLM_ENABLED=false
LLM_API_KEY=                         # your Anthropic API key
LLM_BASE_URL=https://api.anthropic.com
# DeepSeek (OpenAI-compatible): https://api.deepseek.com/chat/completions
LLM_MODEL=claude-haiku-4-5-20251001  # fast, cost-effective for extraction
LLM_MAX_TOKENS=1024

# ── Embedding (BAAI/bge-m3, 1024-dim) ────────────────────────
# Requires: pip install sentence-transformers
# Set EMBEDDING_ENABLED=true after downloading the model
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu                 # or cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIM=1024

# ── Pipeline ─────────────────────────────
ONTOLOGY_VERSION=v0.2.0
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_PREFIX=app
LOG_FILE_MAX_MB=5
LOG_FILE_ENABLED=true
STARTUP_HEALTH_REQUIRED=true

# Worker (crawler + pipeline)
WORKER_CRAWL_LIMIT=10
WORKER_PIPELINE_LIMIT=10
WORKER_SLEEP_SECS=30
